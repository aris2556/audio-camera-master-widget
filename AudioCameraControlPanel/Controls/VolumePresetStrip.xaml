<UserControl x:Class="AudioCameraControlPanel.Controls.VolumePresetStrip"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Horizontal">
        <Button Command="{Binding ZeroCommand, ElementName=Root}"
                Style="{StaticResource PresetButtonStyle}">
            <TextBlock Text="0%" />
        </Button>
        <Button Command="{Binding ThirtyCommand, ElementName=Root}"
                Style="{StaticResource PresetButtonStyle}">
            <TextBlock Text="30%" />
        </Button>
        <Button Command="{Binding ThirtyFiveCommand, ElementName=Root}"
                Style="{StaticResource PresetButtonStyle}">
            <TextBlock Text="35%" />
        </Button>
        <Button Command="{Binding FortyCommand, ElementName=Root}"
                Style="{StaticResource PresetButtonStyle}">
            <TextBlock Text="40%" />
        </Button>
        <Button Command="{Binding FortyFiveCommand, ElementName=Root}"
                Style="{StaticResource PresetButtonStyle}">
            <TextBlock Text="45%" />
        </Button>
        <Button Command="{Binding SixtyCommand, ElementName=Root}"
                Style="{StaticResource PresetButtonStyle}"
                Margin="0">
            <TextBlock Text="60%" />
        </Button>
    </StackPanel>
</UserControl>
