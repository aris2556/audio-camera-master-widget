<Window x:Class="AudioCameraControlPanel.CompactWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AudioCameraControlPanel.Controls"
        Title="{Binding Definition.Title}"
        Icon="Assets/AppIcon.ico"
        SizeToContent="WidthAndHeight"
        MinWidth="280"
        MaxWidth="380"
        MinHeight="0"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}">
    <Border Margin="12"
            Padding="14"
            MaxWidth="356"
            Style="{StaticResource ModuleBorderStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="{Binding Definition.Title}"
                           FontSize="17"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Definition.Description}"
                           Style="{StaticResource CaptionStyle}"
                           Margin="0,2,0,0" />
            </StackPanel>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsMaster, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Command="{Binding Main.MuteAllCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74F;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Mute all" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1"
                            Command="{Binding Main.RefreshAllDevicesCommand}"
                            Margin="6,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Refresh all" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Grid.Row="1"
                        Background="{StaticResource SubtleSurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="10"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE767;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Output" Style="{StaticResource ValueStyle}" />
                        </StackPanel>

                        <ComboBox Grid.Row="1"
                                  ItemsSource="{Binding Main.OutputDevices}"
                                  SelectedItem="{Binding Main.SelectedOutputDevice}"
                                  DisplayMemberPath="DisplayName"
                                  MinWidth="230"
                                  Margin="0,8,0,8" />

                        <Grid Grid.Row="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="56" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Volume"
                                       Style="{StaticResource CaptionStyle}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <Slider Grid.Column="1"
                                    Value="{Binding Main.SelectedOutputVolume, UpdateSourceTrigger=PropertyChanged}"
                                    IsEnabled="{Binding Main.CanControlOutputVolume}"
                                    MinWidth="130"
                                    VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Main.SelectedOutputVolume, StringFormat={}{0:0}%}"
                                       Style="{StaticResource ValueStyle}"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right"
                                       Margin="8,0,10,0" />
                            <Button Grid.Column="3"
                                    Command="{Binding Main.ToggleOutputMuteCommand}"
                                    IsEnabled="{Binding Main.CanControlOutputMute}"
                                    Margin="0">
                                <TextBlock Text="{Binding Main.OutputMuteButtonText}" />
                            </Button>
                        </Grid>

                        <Grid Grid.Row="3" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Set"
                                       Style="{StaticResource CaptionStyle}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <controls:VolumePresetStrip Grid.Column="1"
                                                         ZeroCommand="{Binding Main.SetOutputVolume0Command}"
                                                         ThirtyCommand="{Binding Main.SetOutputVolume30Command}"
                                                         FortyFiveCommand="{Binding Main.SetOutputVolume45Command}"
                                                         SixtyCommand="{Binding Main.SetOutputVolume60Command}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Background="{StaticResource SubtleSurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="10"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE720;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Microphone" Style="{StaticResource ValueStyle}" />
                        </StackPanel>

                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox ItemsSource="{Binding Main.InputDevices}"
                                      SelectedItem="{Binding Main.SelectedInputDevice}"
                                      DisplayMemberPath="DisplayName"
                                      Margin="0,0,8,0" />
                            <Button Grid.Column="1"
                                    Command="{Binding Main.ToggleInputMuteCommand}"
                                    IsEnabled="{Binding Main.CanControlInputMute}"
                                    Margin="0">
                                <TextBlock Text="{Binding Main.InputMuteButtonText}" />
                            </Button>
                        </Grid>

                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="56" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Input level"
                                       Style="{StaticResource CaptionStyle}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0" />
                            <Slider Grid.Column="1"
                                    Value="{Binding Main.SelectedInputVolume, UpdateSourceTrigger=PropertyChanged}"
                                    IsEnabled="{Binding Main.CanControlInputVolume}"
                                    MinWidth="130"
                                    VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Main.SelectedInputVolume, StringFormat={}{0:0}%}"
                                       Style="{StaticResource ValueStyle}"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right" />

                            <TextBlock Grid.Row="1"
                                       Text="Set"
                                       Style="{StaticResource CaptionStyle}"
                                       VerticalAlignment="Center"
                                       Margin="0,8,10,0" />
                            <controls:VolumePresetStrip Grid.Row="1"
                                                         Grid.Column="1"
                                                         Grid.ColumnSpan="2"
                                                         ZeroCommand="{Binding Main.SetInputVolume0Command}"
                                                         ThirtyCommand="{Binding Main.SetInputVolume30Command}"
                                                         FortyFiveCommand="{Binding Main.SetInputVolume45Command}"
                                                         SixtyCommand="{Binding Main.SetInputVolume60Command}"
                                                         Margin="0,8,0,0" />

                            <TextBlock Grid.Row="2"
                                       Text="Meter"
                                       Style="{StaticResource CaptionStyle}"
                                       VerticalAlignment="Center"
                                       Margin="0,8,10,0" />
                            <ProgressBar Grid.Row="2"
                                         Grid.Column="1"
                                         Minimum="0"
                                         Maximum="100"
                                         Height="12"
                                         Value="{Binding Main.InputPeakLevel, Mode=OneWay}"
                                         MinWidth="130"
                                         Margin="0,8,0,0"
                                         VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="2"
                                       Text="{Binding Main.InputPeakLevel, StringFormat={}{0:0}%}"
                                       Style="{StaticResource ValueStyle}"
                                       VerticalAlignment="Center"
                                       TextAlignment="Right"
                                       Margin="0,8,0,0" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="3"
                        Background="{StaticResource SubtleSurfaceBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="7"
                        Padding="10"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Privacy"
                                   Style="{StaticResource CaptionStyle}"
                                   Margin="0,0,0,8" />
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Command="{Binding Main.OpenMicrophonePrivacyCommand}" Margin="0,0,6,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE720;" Style="{StaticResource IconStyle}" />
                                    <TextBlock Text="Mic privacy" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1"
                                    Command="{Binding Main.OpenCameraPrivacyCommand}"
                                    Margin="6,0,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72E;" Style="{StaticResource IconStyle}" />
                                    <TextBlock Text="Cam privacy" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <Grid Grid.Row="4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Command="{Binding Main.OpenSoundSettingsCommand}" Margin="0,0,6,8">
                        <TextBlock Text="Sound" />
                    </Button>
                    <Button Grid.Column="1"
                            Command="{Binding Main.OpenAppVolumeSettingsCommand}"
                            Margin="6,0,6,8">
                        <TextBlock Text="Mixer" />
                    </Button>
                    <Button Grid.Column="2"
                            Command="{Binding Main.OpenCameraSettingsCommand}"
                            Margin="6,0,0,8">
                        <TextBlock Text="Camera" />
                    </Button>
                    <Button Grid.Row="1"
                            Command="{Binding Main.RefreshOutputDevicesCommand}"
                            Margin="0,0,6,0">
                        <TextBlock Text="Out refresh" />
                    </Button>
                    <Button Grid.Row="1"
                            Grid.Column="1"
                            Command="{Binding Main.RefreshInputDevicesCommand}"
                            Margin="6,0,6,0">
                        <TextBlock Text="Mic refresh" />
                    </Button>
                    <Button Grid.Row="1"
                            Grid.Column="2"
                            Click="CloseButton_Click"
                            Margin="6,0,0,0">
                        <TextBlock Text="Close" />
                    </Button>
                    <Button Grid.Row="2"
                            Grid.ColumnSpan="3"
                            Command="{Binding Main.OpenControlPanelCommand}"
                            Margin="0,8,0,0">
                        <TextBlock Text="Full control panel" />
                    </Button>
                </Grid>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsOutput, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ComboBox Grid.Row="0"
                          ItemsSource="{Binding Main.OutputDevices}"
                          SelectedItem="{Binding Main.SelectedOutputDevice}"
                          DisplayMemberPath="DisplayName"
                          Margin="0,0,0,12" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="56" />
                    </Grid.ColumnDefinitions>
                    <Slider Value="{Binding Main.SelectedOutputVolume, UpdateSourceTrigger=PropertyChanged}"
                            IsEnabled="{Binding Main.CanControlOutputVolume}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Main.SelectedOutputVolume, StringFormat={}{0:0}%}"
                               Style="{StaticResource ValueStyle}"
                               VerticalAlignment="Center"
                               TextAlignment="Right" />
                </Grid>

                <controls:VolumePresetStrip Grid.Row="2"
                                             ZeroCommand="{Binding Main.SetOutputVolume0Command}"
                                             ThirtyCommand="{Binding Main.SetOutputVolume30Command}"
                                             FortyFiveCommand="{Binding Main.SetOutputVolume45Command}"
                                             SixtyCommand="{Binding Main.SetOutputVolume60Command}"
                                             Margin="0,10,0,0" />

                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Command="{Binding Main.ToggleOutputMuteCommand}"
                            IsEnabled="{Binding Main.CanControlOutputMute}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74F;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="{Binding Main.OutputMuteButtonText}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding Main.RefreshOutputDevicesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding Main.OpenSoundSettingsCommand}" Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Settings" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="4"
                           Text="{Binding Main.OutputStatusText}"
                           Style="{StaticResource CaptionStyle}"
                           Margin="0,12,0,0" />
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsInput, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ComboBox Grid.Row="0"
                          ItemsSource="{Binding Main.InputDevices}"
                          SelectedItem="{Binding Main.SelectedInputDevice}"
                          DisplayMemberPath="DisplayName"
                          Margin="0,0,0,12" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="56" />
                    </Grid.ColumnDefinitions>
                    <Slider Value="{Binding Main.SelectedInputVolume, UpdateSourceTrigger=PropertyChanged}"
                            IsEnabled="{Binding Main.CanControlInputVolume}"
                            VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Main.SelectedInputVolume, StringFormat={}{0:0}%}"
                               Style="{StaticResource ValueStyle}"
                               VerticalAlignment="Center"
                               TextAlignment="Right" />
                </Grid>

                <controls:VolumePresetStrip Grid.Row="2"
                                             ZeroCommand="{Binding Main.SetInputVolume0Command}"
                                             ThirtyCommand="{Binding Main.SetInputVolume30Command}"
                                             FortyFiveCommand="{Binding Main.SetInputVolume45Command}"
                                             SixtyCommand="{Binding Main.SetInputVolume60Command}"
                                             Margin="0,10,0,0" />

                <Grid Grid.Row="3" Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="56" />
                    </Grid.ColumnDefinitions>
                    <ProgressBar Minimum="0"
                                 Maximum="100"
                                 Height="12"
                                 Value="{Binding Main.InputPeakLevel, Mode=OneWay}"
                                 VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding Main.InputPeakLevel, StringFormat={}{0:0}%}"
                               Style="{StaticResource ValueStyle}"
                               VerticalAlignment="Center"
                               TextAlignment="Right" />
                </Grid>

                <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Command="{Binding Main.ToggleInputMuteCommand}"
                            IsEnabled="{Binding Main.CanControlInputMute}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74F;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="{Binding Main.InputMuteButtonText}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding Main.RefreshInputDevicesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72C;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Refresh" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding Main.OpenMicrophonePrivacyCommand}" Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Privacy" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Row="5"
                           Text="{Binding Main.InputStatusText}"
                           Style="{StaticResource CaptionStyle}"
                           Margin="0,12,0,0" />
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsCamera, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox ItemsSource="{Binding Main.Cameras}"
                              SelectedItem="{Binding Main.SelectedCamera}"
                              DisplayMemberPath="DisplayName"
                              Margin="0,0,8,0" />
                    <Button Grid.Column="1"
                            Command="{Binding Main.ToggleCameraPreviewCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0">
                        <TextBlock Text="{Binding Main.CameraPreviewButtonText}"
                                   Foreground="#FFFFFF"
                                   FontWeight="SemiBold" />
                    </Button>
                </Grid>

                <controls:CameraPreviewPane Grid.Row="1"
                                             Frame="{Binding Main.CameraFrame}"
                                             IsStopped="{Binding Main.IsCameraPreviewStopped}"
                                             PreviewMinHeight="170" />

                <TextBlock Grid.Row="2"
                           Text="{Binding Main.CameraStatusText}"
                           Style="{StaticResource CaptionStyle}"
                           Margin="0,10,0,0" />
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsSettings, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button Grid.Row="0" Command="{Binding Main.OpenSoundSettingsCommand}" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE767;" Style="{StaticResource IconStyle}" />
                        <TextBlock Text="Sound settings" />
                    </StackPanel>
                </Button>
                <Button Grid.Row="1" Command="{Binding Main.OpenAppVolumeSettingsCommand}" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE9E9;" Style="{StaticResource IconStyle}" />
                        <TextBlock Text="App volume mixer" />
                    </StackPanel>
                </Button>
                <Button Grid.Row="2" Command="{Binding Main.OpenCameraSettingsCommand}" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE722;" Style="{StaticResource IconStyle}" />
                        <TextBlock Text="Camera settings" />
                    </StackPanel>
                </Button>
                <Button Grid.Row="3" Command="{Binding Main.OpenCameraPrivacyCommand}" Margin="0,0,0,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72E;" Style="{StaticResource IconStyle}" />
                        <TextBlock Text="Camera privacy" />
                    </StackPanel>
                </Button>
                <Button Grid.Row="4" Command="{Binding Main.OpenMicrophonePrivacyCommand}" Margin="0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE720;" Style="{StaticResource IconStyle}" />
                        <TextBlock Text="Microphone privacy" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
