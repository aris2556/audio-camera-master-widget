<Window x:Class="AudioCameraControlPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:AudioCameraControlPanel.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Audio Camera Control Panel"
        Icon="Assets/AppIcon.ico"
        Width="1080"
        Height="860"
        MinWidth="900"
        MinHeight="700"
        Background="{StaticResource WindowBackgroundBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Audio Camera Control Panel"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Local endpoint and preview controls"
                               Style="{StaticResource CaptionStyle}"
                               Margin="0,3,0,0" />
                    <WrapPanel Margin="0,10,0,0">
                        <Button Command="{Binding OpenMasterWidgetCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" Style="{StaticResource IconStyle}" />
                                <TextBlock Text="Master widget" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenOutputWidgetCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE767;" Style="{StaticResource IconStyle}" />
                                <TextBlock Text="Output widget" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenInputWidgetCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE720;" Style="{StaticResource IconStyle}" />
                                <TextBlock Text="Input widget" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenCameraWidgetCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE722;" Style="{StaticResource IconStyle}" />
                                <TextBlock Text="Camera widget" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenSettingsWidgetCommand}" Margin="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" Style="{StaticResource IconStyle}" />
                                <TextBlock Text="Settings widget" />
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>

                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding OpenSoundSettingsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE767;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Sound" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenAppVolumeSettingsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9E9;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="App volume" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenCameraSettingsCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE722;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Camera" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenCameraPrivacyCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Camera privacy" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding OpenMicrophonePrivacyCommand}" Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE720;" Style="{StaticResource IconStyle}" />
                            <TextBlock Text="Mic privacy" />
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource ChipBorderStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Output" Style="{StaticResource CaptionStyle}" />
                        <TextBlock Text="{Binding DefaultOutputText}"
                                   Style="{StaticResource ValueStyle}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource ChipBorderStyle}" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="Input" Style="{StaticResource CaptionStyle}" />
                        <TextBlock Text="{Binding DefaultInputText}"
                                   Style="{StaticResource ValueStyle}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource ChipBorderStyle}"
                        Background="{StaticResource SuccessSubtleBrush}"
                        BorderBrush="#BDE8D0"
                        Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Camera preview" Style="{StaticResource CaptionStyle}" />
                        <TextBlock Text="{Binding CameraPreviewStateText}"
                                   Style="{StaticResource ValueStyle}"
                                   Foreground="{StaticResource SuccessBrush}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2"
                    Style="{StaticResource ModuleBorderStyle}"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="34"
                                    Height="34"
                                    Background="{StaticResource AccentSubtleBrush}"
                                    CornerRadius="6"
                                    Margin="0,0,10,0">
                                <TextBlock Text="&#xE767;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="{StaticResource AccentBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Output Audio" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding OutputStatusText}" Style="{StaticResource CaptionStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                            <Button Command="{Binding RefreshOutputDevicesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72C;" Style="{StaticResource IconStyle}" />
                                    <TextBlock Text="Refresh" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding OpenSoundSettingsCommand}" Margin="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" Style="{StaticResource IconStyle}" />
                                    <TextBlock Text="Settings" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Selected device"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CaptionStyle}" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding OutputDevices}"
                                  SelectedItem="{Binding SelectedOutputDevice}"
                                  DisplayMemberPath="DisplayName"
                                  Margin="0" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="68" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Volume"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CaptionStyle}" />
                        <Slider Grid.Column="1"
                                Value="{Binding SelectedOutputVolume, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding CanControlOutputVolume}"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding SelectedOutputVolume, StringFormat={}{0:0}%}"
                                   Style="{StaticResource ValueStyle}"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right"
                                   Margin="10,0,14,0" />
                        <Button Grid.Column="3"
                                Command="{Binding ToggleOutputMuteCommand}"
                                IsEnabled="{Binding CanControlOutputMute}"
                                Margin="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74F;" Style="{StaticResource IconStyle}" />
                                <TextBlock Text="{Binding OutputMuteButtonText}" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Presets"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CaptionStyle}" />
                        <controls:VolumePresetStrip Grid.Column="1"
                                                     ZeroCommand="{Binding SetOutputVolume0Command}"
                                                     ThirtyCommand="{Binding SetOutputVolume30Command}"
                                                     ThirtyFiveCommand="{Binding SetOutputVolume35Command}"
                                                     FortyCommand="{Binding SetOutputVolume40Command}"
                                                     FortyFiveCommand="{Binding SetOutputVolume45Command}"
                                                     SixtyCommand="{Binding SetOutputVolume60Command}" />
                    </Grid>

                    <Border Grid.Row="4"
                            Background="{StaticResource SubtleSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,7"
                            Margin="0,12,0,0">
                        <TextBlock Text="{Binding DefaultOutputText}" Style="{StaticResource CaptionStyle}" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Style="{StaticResource ModuleBorderStyle}"
                    Margin="0,0,0,14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="34"
                                    Height="34"
                                    Background="{StaticResource SuccessSubtleBrush}"
                                    CornerRadius="6"
                                    Margin="0,0,10,0">
                                <TextBlock Text="&#xE720;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="{StaticResource SuccessBrush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Input / Microphone" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding InputStatusText}" Style="{StaticResource CaptionStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                            <Button Command="{Binding RefreshInputDevicesCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72C;" Style="{StaticResource IconStyle}" />
                                    <TextBlock Text="Refresh" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding OpenMicrophonePrivacyCommand}" Margin="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72E;" Style="{StaticResource IconStyle}" />
                                    <TextBlock Text="Privacy" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Selected device"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CaptionStyle}" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding InputDevices}"
                                  SelectedItem="{Binding SelectedInputDevice}"
                                  DisplayMemberPath="DisplayName"
                                  Margin="0" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="68" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Input level"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CaptionStyle}" />
                        <Slider Grid.Column="1"
                                Value="{Binding SelectedInputVolume, UpdateSourceTrigger=PropertyChanged}"
                                IsEnabled="{Binding CanControlInputVolume}"
                                VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding SelectedInputVolume, StringFormat={}{0:0}%}"
                                   Style="{StaticResource ValueStyle}"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right"
                                   Margin="10,0,14,0" />
                        <Button Grid.Column="3"
                                Command="{Binding ToggleInputMuteCommand}"
                                IsEnabled="{Binding CanControlInputMute}"
                                Margin="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74F;" Style="{StaticResource IconStyle}" />
                                <TextBlock Text="{Binding InputMuteButtonText}" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Presets"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CaptionStyle}" />
                        <controls:VolumePresetStrip Grid.Column="1"
                                                     ZeroCommand="{Binding SetInputVolume0Command}"
                                                     ThirtyCommand="{Binding SetInputVolume30Command}"
                                                     ThirtyFiveCommand="{Binding SetInputVolume35Command}"
                                                     FortyCommand="{Binding SetInputVolume40Command}"
                                                     FortyFiveCommand="{Binding SetInputVolume45Command}"
                                                     SixtyCommand="{Binding SetInputVolume60Command}" />
                    </Grid>

                    <Grid Grid.Row="4" Margin="0,13,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="68" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Live meter"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CaptionStyle}" />
                        <Border Grid.Column="1"
                                Background="#E8EEF5"
                                CornerRadius="5"
                                Height="12"
                                VerticalAlignment="Center">
                            <ProgressBar Minimum="0"
                                         Maximum="100"
                                         Height="12"
                                         Value="{Binding InputPeakLevel, Mode=OneWay}" />
                        </Border>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding InputPeakLevel, StringFormat={}{0:0}%}"
                                   Style="{StaticResource ValueStyle}"
                                   VerticalAlignment="Center"
                                   TextAlignment="Right"
                                   Margin="10,0,0,0" />
                    </Grid>

                    <Border Grid.Row="5"
                            Background="{StaticResource SubtleSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,7"
                            Margin="0,12,0,0">
                        <TextBlock Text="{Binding DefaultInputText}" Style="{StaticResource CaptionStyle}" />
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource ModuleBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="34"
                                    Height="34"
                                    Background="#FFF1E7"
                                    CornerRadius="6"
                                    Margin="0,0,10,0">
                                <TextBlock Text="&#xE722;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="16"
                                           Foreground="#A94700"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Webcam" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="{Binding CameraStatusText}" Style="{StaticResource CaptionStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <WrapPanel Grid.Column="1" HorizontalAlignment="Right">
                            <Button Command="{Binding RefreshCamerasCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72C;" Style="{StaticResource IconStyle}" />
                                    <TextBlock Text="Refresh" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding OpenCameraSettingsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" Style="{StaticResource IconStyle}" />
                                    <TextBlock Text="Settings" />
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding OpenCameraPrivacyCommand}" Margin="0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72E;" Style="{StaticResource IconStyle}" />
                                    <TextBlock Text="Privacy" />
                                </StackPanel>
                            </Button>
                        </WrapPanel>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Selected camera"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource CaptionStyle}" />
                        <ComboBox Grid.Column="1"
                                  ItemsSource="{Binding Cameras}"
                                  SelectedItem="{Binding SelectedCamera}"
                                  DisplayMemberPath="DisplayName"
                                  Margin="0,0,12,0" />
                        <Button Grid.Column="2"
                                Command="{Binding ToggleCameraPreviewCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           Foreground="#FFFFFF"
                                           FontSize="14"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="{Binding CameraPreviewButtonText}"
                                           Foreground="#FFFFFF"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <controls:CameraPreviewPane Grid.Row="2"
                                                 Frame="{Binding CameraFrame}"
                                                 IsStopped="{Binding IsCameraPreviewStopped}"
                                                 PreviewMinHeight="360" />

                    <Border Grid.Row="3"
                            Background="{StaticResource SubtleSurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,7"
                            Margin="0,12,0,0">
                        <TextBlock Text="{Binding CameraStatusText}" Style="{StaticResource CaptionStyle}" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
